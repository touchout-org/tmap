rules_version = '2';

// poiHistory: the first real collection, proof-of-concept for the eventual
// full save/load/rename/delete My Archives feature (README § Saving and
// exporting). Everything else is still the original placeholder deny-all,
// pending the real per-user settings/saved-map rules that feature needs.
service cloud.firestore {
  match /databases/{database}/documents {
    match /users/{userId}/poiHistory/{docId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
